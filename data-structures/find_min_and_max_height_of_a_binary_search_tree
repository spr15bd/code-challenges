function Node(value) {
  this.value = value;
  this.left = null;
  this.right = null;
}
function BinarySearchTree() {
  this.root = null;
  // Only change code below this line
  this.findMinHeight = function() {
    if (!this.root) {
      return -1
    } else {
      return findNodeMinHeight(this.root) - 1
    }
    function findNodeMinHeight (node) {
      if (node) {
        return 1 + Math.min(findNodeMinHeight(node.left) ,
         findNodeMinHeight(node.right))
      } else {
        return 0
      }
    }
  }
  this.findMaxHeight = function(tree) {
    if (!this.root) {
      return -1
    } else {
      return findNodeMaxHeight(this.root) - 1
    }
    function findNodeMaxHeight (node) {
      if (node) {
        return 1 + Math.max(findNodeMaxHeight(node.left) ,
         findNodeMaxHeight(node.right))
      } else {
        return null
      }
    }
  }
  this.isBalanced = function() {
    return this.findMinHeight() === this.findMaxHeight()
  }
  // Only change code above this line
}

