function Node(value) {
  this.value = value;
  this.left = null;
  this.right = null;
}
function BinarySearchTree() {
  this.root = null;
  // Only change code below this line
  this.findMin = function() {
    if (!this.root) {
      return null
    } else {
      let currentMin
      let currentNode
      currentNode = this.root
      currentMin = this.root.value
      while (currentNode) {
        currentNode = currentNode?.left
        if (currentNode) {
          currentMin = currentNode?.value
        }
      }
      return currentMin
    }
  }
  this.findMax = function() {
    if (!this.root) {
      return null
    } else {
      let currentMax
      let currentNode
      currentNode = this.root
      currentMax = this.root.value
      while (currentNode) {
        currentNode = currentNode?.right
        if (currentNode) {
          currentMax = currentNode?.value
        }
      }
      return currentMax
    }
  }
  // Only change code above this line
}

