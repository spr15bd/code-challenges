function Node(value) {
  this.value = value;
  this.left = null;
  this.right = null;
}
function BinarySearchTree() {
  this.root = null;
}
function isBinarySearchTree(tree) {
  // Only change code below this line
  //check if root is a bst
  if (!tree) return true
  else if ((!tree.left?.value || tree.left?.value < tree.value) && (!tree.right?.value || tree.value <= tree.right?.value)) {
    return isBinarySearchTree(tree.left)
    && isBinarySearchTree(tree.right)
  } else {
    return false
  }

