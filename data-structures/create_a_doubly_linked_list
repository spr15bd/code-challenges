var Node = function(data, prev) {
  this.data = data;
  this.prev = prev;
  this.next = null;
};
var DoublyLinkedList = function() {
  this.head = null;
  this.tail = null;
  // Only change code below this line
  this.add = function(element, prev) {
    let newNode = new Node(element, prev)
    if (!this.head) {
      this.head = newNode
    } else {
      let currentNode = this.head
      while(currentNode.next) {
        currentNode = currentNode.next
      }
      currentNode.next = newNode
      this.tail = newNode
    }
  }
  this.reverse = function(list) {
    if (!list) {
      return null
    } else {
      let temp = this.tail
      this.tail = this.head
      this.head = temp

      let currentNode = this.head
      currentNode.next = currentNode.prev
      currentNode.prev = null
      
      while (currentNode.next && currentNode.next !== this.tail) {
        currentNode = currentNode.next
        let temp = currentNode
        currentNode.next = currentNode.prev
        currentNode.prev = temp.next
      }
      this.tail.next = null
      this.tail.prev = currentNode
    }
  }
  // Only change code above this line
};

let dll = new DoublyLinkedList()
dll.add("123", null)
dll.add("222", dll.head)
let prev = new Node("222", dll.head)
dll.add("234", prev)
prev = new Node("234", prev)
dll.add("333", prev)

console.log("dll is ", dll)
dll.reverse(dll)
console.log("dll reversed is ", dll)
