var displayTree = tree => console.log(JSON.stringify(tree, null, 2));
function Node(value) {
  this.value = value;
  this.left = null;
  this.right = null;
}
function BinarySearchTree() {
  this.root = null;
  // Only change code below this line
  this.isPresent = function(num) {
    if (!this.root) {
      return false
    }
    let currentItem = this.root
    while (currentItem) {
      console.log("Current item is ", currentItem)
      if (currentItem.value === num) {
        return true
      }
      let bst = new BinarySearchTree() 
      if (currentItem.left) {
        bst.root = currentItem.left
      } else if (currentItem.right) {
        bst.root = currentItem.right
      } else {
        return null
      }
      return bst.isPresent(num)
    }
  }
  // Only change code above this line
}

